  m_Script: {fileID: 11500000, guid: eaf0111981678cb419e23e8855480a38, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  uiText: {fileID: 1364711881}
  audioSrc: {fileID: 239902125}
  dialogueLines:
  - "C\xE0ng \u0111i s\xE2u v\xE0o r\u1EEBng, h\u01A1i th\u1EDF c\u1EE7a b\xF3ng
    t\u1ED1i c\xE0ng tr\u1EDF n\xEAn n\u1EB7ng n\u1EC1."
  - "M\u1ED9t cu\u1ED9c ph\u1EE5c k\xEDch b\u1EA5t ng\u1EDD! \u0110\xE1m qu\xE1i
    v\u1EADt \u0111\xF4ng \u0111\u1EA3o \u0111\xE3 bao v\xE2y Arthur v\xE0 Tel'Annas."
  - "S\u1EE9c c\xF9ng l\u1EF1c ki\u1EC7t, c\u1EA3 hai \u0111\xE3 b\u1ECB ch\xFAng
    b\u1EAFt s\u1ED1ng v\xE0 \xE1p gi\u1EA3i \u0111i trong \u0111\xEAm t\u1ED1i."
  - "C\xE1c OMNI hi\u1EC7n \u0111ang b\u1ECB giam c\u1EA7m b\xEAn trong Ng\u1EE5c
    T\u1ED1i Xi\u1EC1ng X\xEDch c\u1EE7a qu\xE2n \u0111o\xE0n h\u1EAFc \xE1m."
  - "H\xE3y t\xECm c\xE1ch tho\xE1t kh\u1ECFi nh\xE0 giam n\xE0y tr\u01B0\u1EDBc
    khi ch\xFAng th\u1EF1c hi\u1EC7n \xE2m m\u01B0u ti\u1EBFp theo!"
  dialogueSounds:
  - {fileID: 8300000, guid: cf1c5e8113d284f4686700871d7d2871, type: 3}
  - {fileID: 8300000, guid: 567ccd0a95cb6ed499043b9999271bad, type: 3}
  - {fileID: 8300000, guid: 86a7870d8cacd1c48841f2a036540912, type: 3}
